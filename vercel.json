{
  "functions": {
    "api/quote.js": { "memory": 256, "maxDuration": 10 },
    "api/news.js":  { "memory": 256, "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
