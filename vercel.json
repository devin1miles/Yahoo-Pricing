{
  "rewrites": [
    { "source": "/api/quote", "destination": "/api/quote.js" },
    { "source": "/api/news", "destination": "/api/news.js" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
